# Direct Neo4j connection. The Python Neo4j driver accepts bolt://, bolt+s://,
# bolt+ssc://, neo4j://, neo4j+s://, and neo4j+ssc://.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Optional: local TCP-to-WebSocket bridge for a remote Bolt-over-WebSocket
# endpoint. When enabled, the server and CLI rewrite NEO4J_URI in-process to
# the local bridge listener.
# NEO4J_WS_BRIDGE_TARGET=wss://graphker.lab.114514.my.id:443/
# NEO4J_WS_BRIDGE_LISTEN_HOST=127.0.0.1
# NEO4J_WS_BRIDGE_CONNECT_HOST=127.0.0.1
# NEO4J_WS_BRIDGE_LISTEN_PORT=17687
# NEO4J_WS_BRIDGE_ENABLED=true
